1\u0e48\u0e40\u0e2b\u0e47\u0e19\u0e40\u0e21\u0e19\u0e39 [X] \u0e17\u0e33\u0e2d\u0e22\u0e48\u0e32\u0e07\u0e44\u0e23? A: \u0e40\u0e21\u0e19\u0e39\u0e1a\u0e32\u0e07\u0e2d\u0e22\u0e48\u0e32\u0e07\u0e41\u0e2a\u0e14\u0e07\u0e15\u0e32\u0e21 role \u0e40\u0e0a\u0e48\u0e19 \u0e23\u0e32\u0e22\u0e07\u0e32\u0e19\u0e41\u0e2a\u0e14\u0e07\u0e40\u0e09\u0e1e\u0e32\u0e30 Manager \u0e2b\u0e32\u0e01\u0e15\u0e49\u0e2d\u0e07\u0e01\u0e32\u0e23\u0e2a\u0e34\u0e17\u0e18\u0e34\u0e4c\u0e40\u0e1e\u0e34\u0e48\u0e21 \u0e15\u0e34\u0e14\u0e15\u0e48\u0e2d Manager \u0e02\u0e2d\u0e07\u0e04\u0e38\u0e13</p> <p>Q: \u0e02\u0e49\u0e2d\u0e21\u0e39\u0e25\u0e44\u0e21\u0e48\u0e2d\u0e31\u0e1b\u0e40\u0e14\u0e15 \u0e15\u0e49\u0e2d\u0e07\u0e17\u0e33\u0e2d\u0e22\u0e48\u0e32\u0e07\u0e44\u0e23? A: \u0e25\u0e2d\u0e07 refresh \u0e2b\u0e19\u0e49\u0e32 (F5) \u0e2b\u0e23\u0e37\u0e2d logout \u0e41\u0e25\u0e49\u0e27 login \u0e43\u0e2b\u0e21\u0e48</p>"},{"location":"faq/#_3","title":"\u0e1b\u0e31\u0e0d\u0e2b\u0e32\u0e40\u0e17\u0e04\u0e19\u0e34\u0e04","text":"<p>Q: \u0e23\u0e30\u0e1a\u0e1a\u0e0a\u0e49\u0e32\u0e21\u0e32\u0e01 \u0e17\u0e33\u0e2d\u0e22\u0e48\u0e32\u0e07\u0e44\u0e23? A: \u0e25\u0e2d\u0e07\u0e1b\u0e34\u0e14\u0e41\u0e25\u0e49\u0e27\u0e40\u0e1b\u0e34\u0e14 browser \u0e43\u0e2b\u0e21\u0e48 \u0e16\u0e49\u0e32\u0e22\u0e31\u0e07\u0e0a\u0e49\u0e32 \u0e41\u0e08\u0e49\u0e07 support</p> <p>Q: \u0e40\u0e01\u0e34\u0e14 error \"\u0e40\u0e0b\u0e2a\u0e0a\u0e31\u0e19\u0e2b\u0e21\u0e14\u0e2d\u0e32\u0e22\u0e38\" \u0e17\u0e33\u0e2d\u0e22\u0e48\u0e32\u0e07\u0e44\u0e23? A: Login \u0e43\u0e2b\u0e21\u0e48\u0e2d\u0e35\u0e01\u0e04\u0e23\u0e31\u0e49\u0e07</p>"},{"location":"faq/#support","title":"\u0e15\u0e34\u0e14\u0e15\u0e48\u0e2d Support","text":"<ul> <li>Email: support@snocko-tech.com</li> <li>\u0e40\u0e27\u0e25\u0e32\u0e17\u0e33\u0e01\u0e32\u0e23: \u0e08\u0e31\u0e19\u0e17\u0e23\u0e4c-\u0e28\u0e38\u0e01\u0e23\u0e4c 8:00-18:00</li> </ul> <p>\u0e2d\u0e31\u0e1b\u0e40\u0e14\u0e15\u0e25\u0e48\u0e32\u0e2a\u0e38\u0e14: 2026-05-15</p>"},{"location":"getting-started/","title":"\u0e40\u0e23\u0e34\u0e48\u0e21\u0e15\u0e49\u0e19\u0e43\u0e0a\u0e49\u0e07\u0e32\u0e19","text":"<p>\u0e04\u0e39\u0e48\u0e21\u0e37\u0e2d\u0e01\u0e32\u0e23\u0e40\u0e23\u0e34\u0e48\u0e21\u0e15\u0e49\u0e19\u0e43\u0e0a\u0e49\u0e07\u0e32\u0e19\u0e23\u0e30\u0e1a\u0e1a PT Leasing Backoffice</p>"},{"location":"getting-started/#_2","title":"\u0e04\u0e27\u0e32\u0e21\u0e15\u0e49\u0e2d\u0e07\u0e01\u0e32\u0e23\u0e02\u0e2d\u0e07\u0e23\u0e30\u0e1a\u0e1a","text":"<p>\u0e01\u0e48\u0e2d\u0e19\u0e43\u0e0a\u0e49\u0e07\u0e32\u0e19 \u0e15\u0e23\u0e27\u0e08\u0e2a\u0e2d\u0e1a\u0e43\u0e2b\u0e49\u0e41\u0e19\u0e48\u0e43\u0e08\u0e27\u0e48\u0e32\u0e04\u0e38\u0e13\u0e21\u0e35:</p> <ul> <li>Browser: Chrome 90+, Firefox 90+, \u0e2b\u0e23\u0e37\u0e2d Edge 90+</li> <li>\u0e1a\u0e31\u0e0d\u0e0a\u0e35\u0e1c\u0e39\u0e49\u0e43\u0e0a\u0e49: \u0e44\u0e14\u0e49\u0e23\u0e31\u0e1a\u0e08\u0e32\u0e01 System Admin</li> <li>\u0e23\u0e2b\u0e31\u0e2a\u0e1c\u0e48\u0e32\u0e19: \u0e44\u0e14\u0e49\u0e23\u0e31\u0e1a\u0e17\u0e32\u0e07 email \u0e40\u0e21\u0e37\u0e48\u0e2d\u0e2a\u0e23\u0e49\u0e32\u0e07 account</li> </ul>"},{"location":"getting-started/#login","title":"\u0e01\u0e32\u0e23\u0e40\u0e02\u0e49\u0e32\u0e2a\u0e39\u0e48\u0e23\u0e30\u0e1a\u0e1a (Login)","text":""},{"location":"getting-started/#1-login","title":"\u0e02\u0e31\u0e49\u0e19\u0e15\u0e2d\u0e19\u0e17\u0e35\u0e48 1: \u0e40\u0e1b\u0e34\u0e14\u0e2b\u0e19\u0e49\u0e32 Login","text":"<p>\u0e40\u0e1b\u0e34\u0e14 browser \u0e41\u0e25\u0e30\u0e44\u0e1b\u0e17\u0e35\u0e48: <code>https://ptleasing.snocko-tech.com</code></p>"},{"location":"getting-started/#2","title":"\u0e02\u0e31\u0e49\u0e19\u0e15\u0e2d\u0e19\u0e17\u0e35\u0e48 2: \u0e01\u0e23\u0e2d\u0e01\u0e02\u0e49\u0e2d\u0e21\u0e39\u0e25","text":"<ol> <li>\u0e01\u0e23\u0e2d\u0e01 Email \u0e02\u0e2d\u0e07\u0e04\u0e38\u0e13 (\u0e40\u0e0a\u0e48\u0e19 name@snocko-tech.com)</li> <li>\u0e01\u0e23\u0e2d\u0e01 \u0e23\u0e2b\u0e31\u0e2a\u0e1c\u0e48\u0e32\u0e19</li> <li>\u0e04\u0e25\u0e34\u0e01\u0e1b\u0e38\u0e48\u0e21 \u0e40\u0e02\u0e49\u0e32\u0e2a\u0e39\u0e48\u0e23\u0e30\u0e1a\u0e1a</li> </ol>"},{"location":"getting-started/#3","title":"\u0e02\u0e31\u0e49\u0e19\u0e15\u0e2d\u0e19\u0e17\u0e35\u0e48 3: \u0e40\u0e1b\u0e25\u0e35\u0e48\u0e22\u0e19\u0e23\u0e2b\u0e31\u0e2a\u0e1c\u0e48\u0e32\u0e19\u0e04\u0e23\u0e31\u0e49\u0e07\u0e41\u0e23\u0e01","text":"<p>\u0e40\u0e21\u0e37\u0e48\u0e2d login \u0e04\u0e23\u0e31\u0e49\u0e07\u0e41\u0e23\u0e01 \u0e23\u0e30\u0e1a\u0e1a\u0e08\u0e30\u0e43\u0e2b\u0e49\u0e40\u0e1b\u0e25\u0e35\u0e48\u0e22\u0e19\u0e23\u0e2b\u0e31\u0e2a\u0e1c\u0e48\u0e32\u0e19: - \u0e04\u0e27\u0e32\u0e21\u0e22\u0e32\u0e27: \u0e2d\u0e22\u0e48\u0e32\u0e07\u0e19\u0e49\u0e2d\u0e22 10 \u0e15\u0e31\u0e27\u0e2d\u0e31\u0e01\u0e29\u0e23 - \u0e15\u0e49\u0e2d\u0e07\u0e21\u0e35: \u0e15\u0e31\u0e27\u0e1e\u0e34\u0e21\u0e1e\u0e4c\u0e43\u0e2b\u0e0d\u0e48, \u0e15\u0e31\u0e27\u0e1e\u0e34\u0e21\u0e1e\u0e4c\u0e40\u0e25\u0e47\u0e01, \u0e15\u0e31\u0e27\u0e40\u0e25\u0e02, \u0e41\u0e25\u0e30\u0e2d\u0e31\u0e01\u0e02\u0e23\u0e30\u0e1e\u0e34\u0e40\u0e28\u0e29</p>"},{"location":"getting-started/#logout","title":"\u0e01\u0e32\u0e23\u0e2d\u0e2d\u0e01\u0e08\u0e32\u0e01\u0e23\u0e30\u0e1a\u0e1a (Logout)","text":"<p>\u0e04\u0e25\u0e34\u0e01\u0e17\u0e35\u0e48\u0e0a\u0e37\u0e48\u0e2d\u0e02\u0e2d\u0e07\u0e04\u0e38\u0e13 (\u0e21\u0e38\u0e21\u0e1a\u0e19\u0e02\u0e27\u0e32) \u0e41\u0e25\u0e49\u0e27\u0e40\u0e25\u0e37\u0e2d\u0e01 \u0e2d\u0e2d\u0e01\u0e08\u0e32\u0e01\u0e23\u0e30\u0e1a\u0e1a</p> <p>\u0e2b\u0e21\u0e32\u0e22\u0e40\u0e2b\u0e15\u0e38: \u0e23\u0e30\u0e1a\u0e1a\u0e08\u0e30 logout \u0e2d\u0e31\u0e15\u0e42\u0e19\u0e21\u0e31\u0e15\u0e34\u0e2b\u0e25\u0e31\u0e07\u0e44\u0e21\u0e48\u0e44\u0e14\u0e49\u0e43\u0e0a\u0e49\u0e07\u0e32\u0e19 30 \u0e19\u0e32\u0e17\u0e35</p>"},{"location":"getting-started/#dashboard","title":"\u0e2b\u0e19\u0e49\u0e32\u0e08\u0e2d\u0e2b\u0e25\u0e31\u0e01 (Dashboard)","text":"<p>\u0e2b\u0e25\u0e31\u0e07 login \u0e2a\u0e33\u0e40\u0e23\u0e47\u0e08 \u0e04\u0e38\u0e13\u0e08\u0e30\u0e40\u0e2b\u0e47\u0e19\u0e2b\u0e19\u0e49\u0e32 Dashboard \u0e0b\u0e36\u0e48\u0e07\u0e41\u0e2a\u0e14\u0e07: - \u0e2a\u0e23\u0e38\u0e1b\u0e2a\u0e31\u0e0d\u0e0d\u0e32\u0e17\u0e35\u0e48\u0e23\u0e31\u0e1a\u0e1c\u0e34\u0e14\u0e0a\u0e2d\u0e1a - \u0e01\u0e32\u0e23\u0e41\u0e08\u0e49\u0e07\u0e40\u0e15\u0e37\u0e2d\u0e19\u0e2a\u0e33\u0e04\u0e31\u0e0d - \u0e07\u0e32\u0e19\u0e17\u0e35\u0e48\u0e23\u0e2d\u0e14\u0e33\u0e40\u0e19\u0e34\u0e19\u0e01\u0e32\u0e23</p>"},{"location":"getting-started/#navigation","title":"\u0e01\u0e32\u0e23\u0e19\u0e33\u0e17\u0e32\u0e07 (Navigation)","text":"<p>\u0e40\u0e21\u0e19\u0e39\u0e14\u0e49\u0e32\u0e19\u0e0b\u0e49\u0e32\u0e22\u0e21\u0e35\u0e40\u0e21\u0e19\u0e39\u0e2b\u0e25\u0e31\u0e01\u0e14\u0e31\u0e07\u0e19\u0e35\u0e49:</p> \u0e40\u0e21\u0e19\u0e39 \u0e1f\u0e31\u0e07\u0e01\u0e4c\u0e0a\u0e31\u0e19 Dashboard \u0e2b\u0e19\u0e49\u0e32\u0e2b\u0e25\u0e31\u0e01 \u0e2a\u0e23\u0e38\u0e1b\u0e20\u0e32\u0e1e\u0e23\u0e27\u0e21 \u0e2a\u0e31\u0e0d\u0e0d\u0e32 \u0e08\u0e31\u0e14\u0e01\u0e32\u0e23\u0e2a\u0e31\u0e0d\u0e0d\u0e32\u0e40\u0e0a\u0e48\u0e32 \u0e25\u0e39\u0e01\u0e04\u0e49\u0e32 \u0e08\u0e31\u0e14\u0e01\u0e32\u0e23\u0e02\u0e49\u0e2d\u0e21\u0e39\u0e25\u0e25\u0e39\u0e01\u0e04\u0e49\u0e32 \u0e01\u0e32\u0e23\u0e0a\u0e33\u0e23\u0e30 \u0e1a\u0e31\u0e19\u0e17\u0e36\u0e01\u0e41\u0e25\u0e30\u0e15\u0e34\u0e14\u0e15\u0e32\u0e21\u0e01\u0e32\u0e23\u0e0a\u0e33\u0e23\u0e30 \u0e23\u0e32\u0e22\u0e07\u0e32\u0e19 \u0e23\u0e32\u0e22\u0e07\u0e32\u0e19\u0e15\u0e48\u0e32\u0e07 \u0e46 (Manager \u0e40\u0e17\u0e48\u0e32\u0e19\u0e31\u0e49\u0e19) \u0e01\u0e32\u0e23\u0e15\u0e31\u0e49\u0e07\u0e04\u0e48\u0e32 \u0e15\u0e31\u0e49\u0e07\u0e04\u0e48\u0e32 profile \u0e02\u0e2d\u0e07\u0e04\u0e38\u0e13"},{"location":"getting-started/#login_1","title":"\u0e16\u0e49\u0e32 Login \u0e44\u0e21\u0e48\u0e44\u0e14\u0e49","text":"\u0e1b\u0e31\u0e0d\u0e2b\u0e32 \u0e27\u0e34\u0e18\u0e35\u0e41\u0e01\u0e49 \u0e25\u0e37\u0e21\u0e23\u0e2b\u0e31\u0e2a\u0e1c\u0e48\u0e32\u0e19 \u0e04\u0e25\u0e34\u0e01 \"\u0e25\u0e37\u0e21\u0e23\u0e2b\u0e31\u0e2a\u0e1c\u0e48\u0e32\u0e19\" \u0e43\u0e15\u0e49\u0e1b\u0e38\u0e48\u0e21 Login Account \u0e16\u0e39\u0e01 lock \u0e15\u0e34\u0e14\u0e15\u0e48\u0e2d Admin: admin@snocko-tech.com \u0e44\u0e21\u0e48\u0e21\u0e35 account \u0e02\u0e2d\u0e08\u0e32\u0e01 Manager \u0e2b\u0e23\u0e37\u0e2d HR <p>\u0e40\u0e27\u0e2d\u0e23\u0e4c\u0e0a\u0e31\u0e19: 1.0.0 | \u0e2d\u0e31\u0e1b\u0e40\u0e14\u0e15\u0e25\u0e48\u0e32\u0e2a\u0e38\u0e14: 2026-05-15</p>"},{"location":"glossary/","title":"\u0e04\u0e33\u0e28\u0e31\u0e1e\u0e17\u0e4c / Glossary","text":"<p>\u0e04\u0e33\u0e28\u0e31\u0e1e\u0e17\u0e4c\u0e2a\u0e33\u0e2b\u0e23\u0e31\u0e1a\u0e1c\u0e39\u0e49\u0e43\u0e0a\u0e49\u0e07\u0e32\u0e19\u0e23\u0e30\u0e1a\u0e1a PT Leasing Backoffice</p> \u0e04\u0e33\u0e28\u0e31\u0e1e\u0e17\u0e4c \u0e04\u0e27\u0e32\u0e21\u0e2b\u0e21\u0e32\u0e22 \u0e2a\u0e31\u0e0d\u0e0d\u0e32\u0e40\u0e0a\u0e48\u0e32 \u0e02\u0e49\u0e2d\u0e15\u0e01\u0e25\u0e07\u0e23\u0e30\u0e2b\u0e27\u0e48\u0e32\u0e07\u0e1a\u0e23\u0e34\u0e29\u0e31\u0e17\u0e41\u0e25\u0e30\u0e25\u0e39\u0e01\u0e04\u0e49\u0e32\u0e2a\u0e33\u0e2b\u0e23\u0e31\u0e1a\u0e01\u0e32\u0e23\u0e40\u0e0a\u0e48\u0e32\u0e2a\u0e34\u0e19\u0e17\u0e23\u0e31\u0e1e\u0e22\u0e4c \u0e1c\u0e39\u0e49\u0e40\u0e0a\u0e48\u0e32 (Lessee) \u0e25\u0e39\u0e01\u0e04\u0e49\u0e32\u0e17\u0e35\u0e48\u0e17\u0e33\u0e2a\u0e31\u0e0d\u0e0d\u0e32\u0e40\u0e0a\u0e48\u0e32 \u0e04\u0e48\u0e32\u0e07\u0e27\u0e14 \u0e40\u0e07\u0e34\u0e19\u0e17\u0e35\u0e48\u0e25\u0e39\u0e01\u0e04\u0e49\u0e32\u0e0a\u0e33\u0e23\u0e30\u0e40\u0e1b\u0e47\u0e19\u0e23\u0e32\u0e22\u0e40\u0e14\u0e37\u0e2d\u0e19\u0e15\u0e32\u0e21\u0e2a\u0e31\u0e0d\u0e0d\u0e32 \u0e2a\u0e16\u0e32\u0e19\u0e30\u0e2a\u0e31\u0e0d\u0e0d\u0e32 Active \u0e2a\u0e31\u0e0d\u0e0d\u0e32\u0e17\u0e35\u0e48\u0e01\u0e33\u0e25\u0e31\u0e07\u0e43\u0e0a\u0e49\u0e07\u0e32\u0e19\u0e2d\u0e22\u0e39\u0e48 \u0e2a\u0e16\u0e32\u0e19\u0e30\u0e2a\u0e31\u0e0d\u0e0d\u0e32 Expired \u0e2a\u0e31\u0e0d\u0e0d\u0e32\u0e17\u0e35\u0e48\u0e2b\u0e21\u0e14\u0e2d\u0e32\u0e22\u0e38\u0e41\u0e25\u0e49\u0e27 \u0e2a\u0e16\u0e32\u0e19\u0e30\u0e2a\u0e31\u0e0d\u0e0d\u0e32 Terminated \u0e2a\u0e31\u0e0d\u0e0d\u0e32\u0e17\u0e35\u0e48\u0e16\u0e39\u0e01\u0e22\u0e01\u0e40\u0e25\u0e34\u0e01\u0e01\u0e48\u0e2d\u0e19\u0e01\u0e33\u0e2b\u0e19\u0e14 KYC Know Your Customer \u2014 \u0e01\u0e23\u0e30\u0e1a\u0e27\u0e19\u0e01\u0e32\u0e23\u0e15\u0e23\u0e27\u0e08\u0e2a\u0e2d\u0e1a\u0e15\u0e31\u0e27\u0e15\u0e19\u0e25\u0e39\u0e01\u0e04\u0e49\u0e32 Credit Score \u0e04\u0e30\u0e41\u0e19\u0e19\u0e40\u0e04\u0e23\u0e14\u0e34\u0e15\u0e02\u0e2d\u0e07\u0e25\u0e39\u0e01\u0e04\u0e49\u0e32 \u0e43\u0e0a\u0e49\u0e1b\u0e23\u0e30\u0e40\u0e21\u0e34\u0e19\u0e04\u0e27\u0e32\u0e21\u0e40\u0e2a\u0e35\u0e48\u0e22\u0e07 NPL \u0e2a\u0e31\u0e0d\u0e0d\u0e32\u0e17\u0e35\u0e48\u0e1c\u0e34\u0e14\u0e19\u0e31\u0e14\u0e0a\u0e33\u0e23\u0e30 (Non-Performing Loan) Dashboard \u0e2b\u0e19\u0e49\u0e32\u0e41\u0e2a\u0e14\u0e07\u0e20\u0e32\u0e1e\u0e23\u0e27\u0e21\u0e02\u0e2d\u0e07\u0e07\u0e32\u0e19\u0e17\u0e31\u0e49\u0e07\u0e2b\u0e21\u0e14 Manager \u0e1c\u0e39\u0e49\u0e08\u0e31\u0e14\u0e01\u0e32\u0e23\u0e17\u0e35\u0e48\u0e21\u0e35\u0e2a\u0e34\u0e17\u0e18\u0e34\u0e4c\u0e2d\u0e19\u0e38\u0e21\u0e31\u0e15\u0e34\u0e2a\u0e31\u0e0d\u0e0d\u0e32 Officer \u0e40\u0e08\u0e49\u0e32\u0e2b\u0e19\u0e49\u0e32\u0e17\u0e35\u0e48\u0e17\u0e35\u0e48\u0e2a\u0e23\u0e49\u0e32\u0e07\u0e41\u0e25\u0e30\u0e08\u0e31\u0e14\u0e01\u0e32\u0e23\u0e2a\u0e31\u0e0d\u0e0d\u0e32 <p>\u0e2d\u0e31\u0e1b\u0e40\u0e14\u0e15\u0e25\u0e48\u0e32\u0e2a\u0e38\u0e14: 2026-05-15</p>"}]}