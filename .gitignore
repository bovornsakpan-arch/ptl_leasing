docs/user-manual/site/

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/
env/

# Environment variables — NEVER commit secrets
.env
.env.local
.env.*.local
*.local

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?
Thumbs.db

# Editor
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# Dashboard sync errors (auto-generated, keep template only)
dashboard/data/sync-errors.json

# Temp files
*.tmp
*.bak
*.orig

# Logs
*.log
logs/

# Coverage
coverage/
.nyc_output/
htmlcov/

# OS
ehthumbs.db
Desktop.ini
